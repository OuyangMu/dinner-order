{
  "name": "dinner-order",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @dinner-order/server",
    "dev:local": "scripts\\dev-local.cmd",
    "dev:local:stop": "scripts\\stop-local.cmd",
    "dev:web": "npm run dev --workspace @dinner-order/web",
    "dev:server": "npm run dev --workspace @dinner-order/server",
    "build": "npm run build --workspace @dinner-order/server && npm run build --workspace @dinner-order/web",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
